# 复制为 .env 后按需填写；勿将真实密钥提交到版本库。
# cp .env.example .env

# ---------------------------------------------------------------------------
# 应用
# ---------------------------------------------------------------------------
APP_NAME=PD API

# ---------------------------------------------------------------------------
# JWT（生产环境务必使用足够长的随机串，勿用示例值）
# ---------------------------------------------------------------------------
JWT_SECRET=replace-with-long-random-secret
JWT_ALGORITHM=HS256

# ---------------------------------------------------------------------------
# MySQL（database_setup / PyMySQL 使用 MYSQL_*；请勿只配置 DATABASE_URL 而省略 MYSQL_*）
# ---------------------------------------------------------------------------
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=your_mysql_user
MYSQL_PASSWORD=your_mysql_password
MYSQL_DATABASE=PD_db
MYSQL_CHARSET=utf8mb4

# 部分模块读取的占位连接串；实际连库以 MYSQL_* 为准
DATABASE_URL=mysql+pymysql://your_mysql_user:your_mysql_password@127.0.0.1:3306/PD_db?charset=utf8mb4

# ---------------------------------------------------------------------------
# HTTP 监听（未设置时 main.py 默认 8007）
# ---------------------------------------------------------------------------
PORT=8007

# ---------------------------------------------------------------------------
# CORS（可选，逗号分隔；不配置则默认 *）
# ---------------------------------------------------------------------------
# CORS_ALLOW_ORIGINS=http://127.0.0.1:3000,http://localhost:3000

# ---------------------------------------------------------------------------
# 日志（可选，详见 app/core/logging.py）
# ---------------------------------------------------------------------------
# LOG_DIR=logs
# LOG_LEVEL=INFO
# LOG_ENABLE_CONSOLE=1
# LOG_ENABLE_FILE=1
# LOG_RETENTION_DAYS=30

# ---------------------------------------------------------------------------
# OpenAI（可选）
# ---------------------------------------------------------------------------
# OPENAI_API_KEY=sk-your-key-here

# ---------------------------------------------------------------------------
# 扣子 Coze 流式对话（可选）
# 支持两套命名：下为历史小写名；亦可使用 COZE_URL / COZE_PROJECT_ID / COZE_SESSION_ID / COZE_BEARER_TOKEN（见 app/core/config.py）
# ---------------------------------------------------------------------------
# Coze_url=https://your-instance.coze.site/stream_run
# project_id=
# session_id=
# YOUR_TOKEN=
# COZE_URL=
# COZE_PROJECT_ID=
# COZE_SESSION_ID=
# COZE_BEARER_TOKEN=
